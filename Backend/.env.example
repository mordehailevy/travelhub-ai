# NODE_ENV=production enforces fail-fast validation: MONGO_URI and JWT_SECRET
# (32+ chars) must be set to real values with no fallback. Leave NODE_ENV
# unset for local dev to keep the friendly defaults below.
PORT=4000
MONGO_URI=mongodb://localhost:27017/travelhub
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
CLIENT_ORIGIN=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
